{
  "name": "Vessel Host (spike)",
  "short_name": "Vessel",
  "description": "Opens .vessel tool bundles.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "background_color": "#26282b",
  "theme_color": "#26282b",
  "icons": [
    { "src": "/icon.svg", "sizes": "any", "type": "image/svg+xml", "purpose": "any" }
  ],
  "file_handlers": [
    {
      "action": "/",
      "accept": { "application/vessel": [".vessel"] },
      "launch_type": "single-client"
    }
  ]
}
