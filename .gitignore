# --- Secrets ---
.env
.env.*.local
# Bundle signing keys: never commit secret keys; the .pub is shareable.
*.key
examples/.keys/*.key

# --- Node / SDK / host build ---
node_modules/
dist/
build/
.vite/
*.tsbuildinfo

# --- Python / bundle authoring ---
__pycache__/
*.pyc
.venv/
.uv/

# --- Pyodide / runtime cache ---
.pyodide-cache/

# --- Build artifacts ---
# Generated bundles live in build output, not source.
# Keep hand-authored example/fixture bundles under tests/fixtures/.
*.vessel
!tests/fixtures/**/*.vessel
# Ship the example tools as ready-to-download bundles (Phase 12).
!examples/**/*.vessel

# --- OS / IDE ---
.DS_Store
Thumbs.db
.idea/
# Windows mark-of-the-web alternate-data-stream cruft (WSL)
*:Zone.Identifier
*Zone.Identifier

# Vendored Pyodide runtime (regenerated by host/scripts/vendor-pyodide.mjs)
host/public/pyodide/
